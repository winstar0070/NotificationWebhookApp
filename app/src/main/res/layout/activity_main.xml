<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7F9"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:id="@+id/projectListSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/appTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Notification Webhooks"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/appSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Choose a project to manage app alerts and webhooks."
            android:textColor="#64748B"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/projectNameEditText"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="Project name"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/addProjectButton"
                android:layout_width="92dp"
                android:layout_height="44dp"
            android:gravity="center"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_primary"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Add"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/manageGlobalWebhooksButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Manage Webhooks"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/manageSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_secondary"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Settings"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="14sp" />

        <ListView
            android:id="@+id/projectListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:cacheColorHint="#00000000"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/projectDetailSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/backToProjectsButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Back to projects"
            android:padding="8dp"
            android:scaleType="center"
            android:src="@drawable/ic_arrow_left"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <TextView
            android:id="@+id/currentProjectTitle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:textColor="#111827"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/projectSettingsButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Project settings"
            android:padding="8dp"
            android:scaleType="center"
            android:src="@drawable/ic_settings"
            android:minHeight="0dp"
            android:minWidth="0dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/appsTabButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/tab_selected"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:layout_weight="1"
            android:text="Apps"
            android:textAllCaps="false"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/webhooksTabButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:background="@drawable/tab_normal"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:layout_weight="1"
            android:text="Destinations"
            android:textAllCaps="false"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/historyTabButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:background="@drawable/tab_normal"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:layout_weight="1"
            android:text="History"
            android:textAllCaps="false"
            android:textSize="14sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/projectWebhookSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Destinations"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Choose project-wide webhook and SMS destinations."
            android:textColor="#64748B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/openWebhookSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_secondary"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Open Webhook Destination Settings"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/smsDestinationEditText"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="SMS destination number"
                android:inputType="phone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/addSmsDestinationButton"
                android:layout_width="72dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_secondary"
                android:gravity="center"
                android:text="Add"
                android:textColor="#111827"
                android:textSize="13sp" />
        </LinearLayout>

        <ListView
            android:id="@+id/projectWebhookListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:cacheColorHint="#00000000"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/appsSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/appsSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Sources"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/appsSectionSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Choose app notification sources and SMS rules."
            android:textColor="#64748B"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/searchAppsEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="Search apps"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textSize="16sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/addAppsModeButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center"
                android:background="@drawable/button_secondary"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Add Apps"
                android:textAllCaps="false"
                android:textColor="#111827"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/smsSourceRuleRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <EditText
                android:id="@+id/smsSourceSenderEditText"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="SMS source sender or phone"
                android:inputType="phone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/smsSourceContainsEditText"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="Optional body contains keyword"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/addSmsSourceButton"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/button_secondary"
                android:gravity="center"
                android:text="Add SMS Source Rule"
                android:textColor="#111827"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/smsSourceRulesText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:text="No SMS source rules yet."
                android:textColor="#475569"
                android:textSize="13sp" />
        </LinearLayout>

        <ListView
            android:id="@+id/appList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:cacheColorHint="#00000000"
            android:divider="@android:color/transparent"
            android:dividerHeight="6dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/emptyAppsText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:background="@drawable/card_background"
            android:gravity="center"
            android:padding="20dp"
            android:text="No selected apps yet. Tap Add Apps to choose notification sources."
            android:textColor="#64748B"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/saveAppsButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center"
            android:background="@drawable/button_primary"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:textColor="#FFFFFF"
            android:text="Done"
            android:textAllCaps="false"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/webhooksSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/webhookUrlEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="Webhook URL"
            android:inputType="textUri"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/webhookMethodSegment"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/methodPostButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/method_segment_selected"
                android:gravity="center"
                android:text="POST"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/methodPutButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/method_segment_normal"
                android:gravity="center"
                android:text="PUT"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/methodPatchButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/method_segment_normal"
                android:gravity="center"
                android:text="PATCH"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/methodGetButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/method_segment_normal"
                android:gravity="center"
                android:text="GET"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/methodDeleteButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/method_segment_normal"
                android:gravity="center"
                android:text="DEL"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/basicAuthCheckBox"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:button="@drawable/checkbox_selector"
            android:buttonTint="@null"
            android:paddingStart="8dp"
            android:text="Use Basic Auth" />

        <EditText
            android:id="@+id/basicAuthUsernameEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="Username"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textSize="16sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/basicAuthPasswordEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textSize="16sp"
            android:visibility="gone" />

        <CheckBox
            android:id="@+id/hmacCheckBox"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:button="@drawable/checkbox_selector"
            android:buttonTint="@null"
            android:paddingStart="8dp"
            android:text="Use HMAC SHA-256" />

        <EditText
            android:id="@+id/hmacSecretEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="HMAC Secret"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textSize="16sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/hmacHeaderEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="HMAC Header (X-Signature)"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Headers"
            android:textColor="#111827"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/headersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/addHeaderButton"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/button_secondary"
            android:gravity="center"
            android:text="+ Header"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/addWebhookButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
            android:gravity="center"
                android:background="@drawable/button_secondary"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Add"
                android:textAllCaps="false"
                android:textColor="#111827"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/updateWebhookButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
            android:gravity="center"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_secondary"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Update"
                android:textAllCaps="false"
                android:textColor="#111827"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/deleteWebhookButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
            android:gravity="center"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_secondary"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Delete"
                android:textAllCaps="false"
                android:textColor="#991B1B"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/testWebhookButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_primary"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:textColor="#FFFFFF"
            android:text="Send Test"
            android:textAllCaps="false"
            android:textSize="15sp" />

        <ListView
            android:id="@+id/webhookListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:cacheColorHint="#00000000"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/settingsSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Settings"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Manage permissions and SMS routing outside app selection."
            android:textColor="#64748B"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notification Listener"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/listenerStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/openListenerSettingsButton"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_secondary"
                android:gravity="center"
                android:text="Open Listener Settings"
                android:textColor="#111827"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SMS Routing"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/smsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/requestSmsPermissionsButton"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_secondary"
                android:gravity="center"
                android:text="Request SMS Permissions"
                android:textColor="#111827"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/smsWebhookCheckBox"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:button="@drawable/checkbox_selector"
                android:buttonTint="@null"
                android:gravity="center_vertical"
                android:text="Send received SMS to webhook"
                android:textColor="#111827"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/smsForwardCheckBox"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:button="@drawable/checkbox_selector"
                android:buttonTint="@null"
                android:gravity="center_vertical"
                android:text="Forward received SMS to another phone"
                android:textColor="#111827"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/smsForwardNumberEditText"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="Forward phone number"
                android:inputType="phone"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/saveSettingsButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_primary"
                android:gravity="center"
                android:text="Save Settings"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/testSmsForwardButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:gravity="center"
                android:text="Send Test SMS"
                android:textColor="#111827"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settingsFeedbackText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/selected_item_background"
                android:padding="12dp"
                android:text="Settings status will appear here."
                android:textColor="#374151"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/historySection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/clearHistoryButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:background="@drawable/button_secondary"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Clear History"
            android:textAllCaps="false"
            android:textColor="#991B1B"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/historySearchEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="Search history"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/historyFilterSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp" />

        <ListView
            android:id="@+id/historyListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:cacheColorHint="#00000000"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:layout_weight="1" />
    </LinearLayout>

    </LinearLayout>

</LinearLayout>
